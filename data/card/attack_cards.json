      "chain": {
        "type": "fall",
        "t": 0.5,
        "max_offset_x": 400,
        "start_height_h": 140,
        "target": "enemy",
        "animation": "res://sprite/meteor_strike.tres",
        "on_land": [
          {
            "type": "aoe_detect",
            "shape": "circle",
            "radius": 35,
            "origin": "parent",
            "target": "player",
            "offset": 0,
