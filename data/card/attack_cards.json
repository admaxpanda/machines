# attack_cards.json 格式说明
#
# 顶层：
#   cards    攻击卡数组
#
# 单张攻击卡：
#   id        唯一标识
#   name      显示名称
#   cost      能量消耗
#   chain     效果链（嵌套字典，每个节点可含回调槽）
#   exhaust   打出后是否消耗（true/false）
#
# 触发器（产生事件，含回调槽）：
#   { "type": "aoe_detect", "radius": 30, "animation": "...", "lifetime": 0.2, "on_detect": [...] }
#   { "type": "spawn_projectile", "speed": 300, "max_range": 200, "animation": "...", "on_hit": [...] }
#   { "type": "boomerang", "origin": "player", "target": "enemy", "length": 150, "time": 0.6,
#     "animation": "...", "on_detect": [...] }
#   { "type": "beam_detect", "origin": "player", "target": "enemy", "length": 100, "width": 10,
#     "tail_width_coeff": 1.0, "color": "#FFFFFF", "lifetime": 0.3, "min_opacity": 0.0, "on_detect": [...] }
#   { "type": "multi_release", "count": 4, "interval": 0.05,
#     "chains": [ { ... }, { ... }, ... ] }
#   { "type": "multi_release_claw", "interval": 0.1,
#     "chains": [ { ... } ] }
#   { "type": "multi_release_drill", "count": { "var": "drill_count" },
#     "damage_formula": { "var": "drill_count", "add": 4 }, "interval": 0.05,
#     "chains": [ { ... } ] }
#   { "type": "ring_detect", "origin": "player", "target": "player", "min_radius": 0,
#     "max_radius": 300, "time": 0.4, "line_width": 3, "color": "#FFFFFF", "on_detect": [...] }
#   { "type": "fall", "t": 0.4, "max_offset_x": 30, "start_height_h": 120,
#     "target": "random_enemy", "animation": "...", "on_land": [...] }
#
# 动态变量引用（用于 count / value 等数值字段）：
#   { "var": "drill_count" }          读取 player.drill_count
#   { "var": "drill_count", "add": 4 }  读取 player.drill_count + 4
#   { "var": "orb_count" }            读取当前充能球数量
#   普通整数值（如 4）不经过变量解析，直接使用
#
# origin/target 可选值：
#   "player" / "enemy" / "parent"
#   "random_enemy" / "lowest_hp_enemy"
#   {"random": [1,2,3,4]}  指定象限的随机方向（1=右下, 2=右上, 3=左上, 4=左下）
#
# 原子效果（叶节点，做一件事）：
#   { "type": "deal_damage", "value": 6 }
#   { "type": "apply_buff", "name": "weak", "value": 1, "duration": 1 }
#   { "type": "knockback" }
#   { "type": "draw_attack_cards", "value": 1 }
#   { "type": "draw_skill_cards", "value": 1 }
#   { "type": "gain_attack_energy", "value": 1 }
#   { "type": "gain_skill_energy", "value": 1 }
#   { "type": "channel_orb", "orb_id": "frost" }
#   { "type": "evoke_all_orbs" }
#   { "type": "spawn_glass_barrier", "origin": "player" }
#   { "type": "spawn_moving_barrier", "origin": "player", "target": "enemy", "time": 0.8 }

{
  "cards": [
    {
      "id": "strike",
      "name": "STRIKE",
      "description": "STRIKE_DESC",
      "cost": 1,
      "cover": "res://sprite/strike_card.png",
      "chain": {
        "type": "aoe_detect",
        "shape": "circle",
        "radius": 30,
        "origin": "player",
        "target": "enemy",
        "offset": 20,
        "animation": "res://sprite/strike.tres",
        "lifetime": 0.2,
        "on_detect": [
          { "type": "deal_damage", "value": 6 },
          { "type": "knockback", "force": 250.0 }
        ]
      },
      "exhaust": false
    },
    {
      "id": "cold_snap",
      "name": "COLD_SNAP",
