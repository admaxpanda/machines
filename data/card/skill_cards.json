      "description": "SIGNAL_BOOST_DESC",
      "cost": 1,
      "cover": "res://sprite/skill_card/signal_boost.png",
      "chain": {
        "type": "signal_boost"
      },
      "exhaust": true
    },
    {
      "id": "double_energy",
      "name": "DOUBLE_ENERGY",
      "description": "DOUBLE_ENERGY_DESC",
      "cost": 1,
      "cover": "res://sprite/skill_card/double_energy.png",
      "chain": {
        "type": "double_skill_energy"
      },
      "exhaust": true
    },
    {
      "id": "boot_sequence",
