
# levels.json 格式说明
#
# 顶层：
#   levels        关卡数组，一个元素代表一关
#
# 单个关卡：
#   id            唯一标识，如 "scene1_level1"
#   scene_index   场景编号，0-2 对应三个大场景
#   level_index   关卡编号，0-4 对应场景内 5 关
#   waves         波次数组
#
# 单条波次（到 start_time 时开始按 spawn_interval 生成敌人，多条波次可并行）：
#   enemy_id       敌人id，引用敌人数据（后续在 data/enemy/ 中定义）
#   start_time     战斗开始后多少秒启动这条波次
#   count          这条波次总共生成多少个敌人
#   spawn_interval 每次生成之间的间隔秒数
#   type           波次类型：normal / elite / boss

{
  "levels": [
    {
      "id": "scene1_level1",
      "scene_index": 0,
      "level_index": 0,
      "waves": [
        {
          "enemy_id": "slime_leaf",
          "start_time": 0.0,
          "count": 20,
          "spawn_interval": 1.0,
          "type": "normal"
        }
      ]
    }
  ]
}
